---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class="pt-16 pb-12">
      <div class="max-w-2xl">
        <h1 class="text-4xl font-bold mb-4 sm:text-5xl">
          {SITE.title}
        </h1>
        
        <p class="text-lg text-muted-foreground mb-6 leading-relaxed">
          {SITE.desc}
        </p>

        <div class="flex flex-wrap gap-3 mb-8">
          <a 
            href="/posts" 
            class="inline-flex items-center gap-2 px-4 py-2 bg-accent text-accent-foreground rounded-md hover:opacity-90 transition-opacity"
          >
            All Posts
            <IconArrowRight class="inline-block w-4 h-4" />
          </a>
          <a 
            href="/about" 
            class="inline-flex items-center gap-2 px-4 py-2 border border-border rounded-md hover:bg-accent/10 transition-colors"
          >
            About
          </a>
        </div>

        <div class="flex items-center gap-4 text-muted-foreground">
          {SOCIALS.map((social) => (
            <a 
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent transition-colors"
              title={social.linkTitle}
            >
              <social.icon class="w-5 h-5" />
              <span class="sr-only">{social.linkTitle}</span>
            </a>
          ))}
          <a 
            href="/rss.xml"
            class="hover:text-accent transition-colors"
            title="RSS Feed"
          >
            <IconRss class="w-5 h-5" />
            <span class="sr-only">RSS Feed</span>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
